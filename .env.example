# ─── Copy to .env.local and fill in real values ───────────────────────────────
# .env.local is gitignored — never commit API keys

# ─── PostgreSQL ───────────────────────────────────────────────────────────────
# Local: data persists in Backend/.data/postgres (bind-mount)
DATABASE_URL=postgresql+asyncpg://trading_os:trading_os_dev@localhost:5432/trading_os

# ─── Redis ────────────────────────────────────────────────────────────────────
# Local: AOF log persists in Backend/.data/redis (bind-mount)
REDIS_URL=redis://localhost:6379

# ─── Queue Backend ────────────────────────────────────────────────────────────
# "memory"  → InMemoryExecutionQueue  (single container, start here)
# "redis"   → RedisExecutionQueue     (multi-container, flip when scaling)
EXECUTION_QUEUE_BACKEND=memory

# ─── Execution ────────────────────────────────────────────────────────────────
# "true"  → paper trades (no real money, simulated fills)
# "false" → live execution via ccxt (⚡ real money — do not flip without testing)
PAPER_MODE=true

# ─── Model Provider ───────────────────────────────────────────────────────────
# "mock"      → deterministic stubs, zero LLM cost (dev default)
# "anthropic" → real Claude via Anthropic API
# "openai"    → real GPT via OpenAI API
MODEL_PROVIDER=mock

# Required when MODEL_PROVIDER=anthropic
ANTHROPIC_API_KEY=
# Override model (default: claude-opus-4-5)
ANTHROPIC_MODEL=claude-opus-4-5

# Required when MODEL_PROVIDER=openai
OPENAI_API_KEY=
# Override model (default: gpt-4o)
OPENAI_MODEL=gpt-4o

# ─── Exchange Credentials (only needed when PAPER_MODE=false) ─────────────────
# Active venue is set via EXCHANGE_ID (must match a key in EXCHANGE_REGISTRY)
EXCHANGE_ID=paper

BINANCE_API_KEY=
BINANCE_API_SECRET=

KRAKEN_API_KEY=
KRAKEN_API_SECRET=

COINBASE_API_KEY=
COINBASE_API_SECRET=

# Alpaca (equities + crypto) — uses paper API URL by default
ALPACA_API_KEY=
ALPACA_API_SECRET=
ALPACA_BASE_URL=https://paper-api.alpaca.markets

# ─── Environment ──────────────────────────────────────────────────────────────
ENV=development
