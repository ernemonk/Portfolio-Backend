# Trading OS Local AI Configuration
# Copy to .env in Backend/ directory

# ═══════════════════════════════════════════════════════════
# AI PERFORMANCE CONFIGURATION
# ═══════════════════════════════════════════════════════════

# Performance tier: fast, balanced, quality, full
AI_PERFORMANCE_TIER=balanced

# Auto-download models on startup
AI_AUTO_DOWNLOAD=true

# Preload priority models for faster first responses  
AI_PRELOAD_MODELS=true

# Maximum memory allocation (GB)
AI_MAX_MEMORY_GB=8

# ═══════════════════════════════════════════════════════════
# QUICK TIER SWITCHING
# ═══════════════════════════════════════════════════════════

# For development/testing (fast responses)
# AI_PERFORMANCE_TIER=fast

# For production trading (balanced)
# AI_PERFORMANCE_TIER=balanced  

# For research/analysis (high quality)
# AI_PERFORMANCE_TIER=quality

# For maximum capability (all models)
# AI_PERFORMANCE_TIER=full